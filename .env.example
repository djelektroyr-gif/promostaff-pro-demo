# Режим округления оплачиваемых часов:
# none | quarter_up | half_up | hour_up
BILLING_ROUNDING_MODE=quarter_up
# Скопируйте в .env и подставьте значения

# Токен бота @BotFather
BOT_TOKEN=

# Ваш числовой Telegram user id (админ: /admin, создание проектов/смен, удаление тестовых заказчиков)
ADMIN_USER_ID=0

# Опционально: PostgreSQL для сохранения данных между деплоями.
# Если не задано — используется локальный SQLite (данные могут сбрасываться на хостинге).
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
